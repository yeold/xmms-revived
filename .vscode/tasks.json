{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "make",
            "args": ["CFLAGS=-g3 -O0 -Wall -Wpointer-arith -finline-functions", "-j$(nproc)"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-debug-clean",
            "type": "shell",
            "command": "make",
            "args": ["clean", "&&", "make", "CFLAGS=-g3 -O0 -Wall -Wpointer-arith -finline-functions", "-j$(nproc)"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-debug-incremental",
            "type": "shell",
            "command": "make",
            "args": ["CFLAGS=-g3 -O0 -Wall -Wpointer-arith -finline-functions", "-j$(nproc)"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-release",
            "type": "shell", 
            "command": "make",
            "args": ["-j$(nproc)"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "reconfigure-debug",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "make distclean || true && CFLAGS='-g3 -O0' ./configure --enable-debug --prefix=/usr/local"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "install",
            "type": "shell",
            "command": "make",
            "args": ["install"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "run-xmms",
            "type": "shell",
            "command": "${workspaceFolder}/xmms/xmms",
            "args": [],
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "build-release"
        },
        {
            "label": "run-xmms-debug-binary",
            "type": "shell",
            "command": "${workspaceFolder}/xmms/.libs/xmms",
            "args": ["--version"],
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "LD_LIBRARY_PATH": "${workspaceFolder}/libxmms/.libs:/usr/local/lib64:${env:LD_LIBRARY_PATH}"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "build-debug"
        }
    ]
}
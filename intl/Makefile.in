# Makefile for directory with message catalog handling library of GNU gettext.
# Copyright (C) 1995-1998, 2000-2003 Free Software Foundation, Inc.

PACKAGE = xmms
VERSION = 1.18.1

SHELL = /bin/sh

srcdir = .
top_srcdir = ..


prefix = /usr/local
exec_prefix = ${prefix}
transform = s,x,x,
libdir = ${exec_prefix}/lib64
includedir = ${prefix}/include
datadir = ${prefix}/share
localedir = $(datadir)/locale
gettextsrcdir = $(datadir)/gettext/intl
aliaspath = $(localedir)
subdir = intl

INSTALL = /usr/bin/install -c
INSTALL_DATA = ${INSTALL} -m 644
MKINSTALLDIRS = @MKINSTALLDIRS@

AR = ar
CC = gcc
LIBTOOL = $(SHELL) $(top_builddir)/libtool
RANLIB = ranlib
YACC = @YACC@ -y -d
YFLAGS = --name-prefix=__gettext

DEFS = -DLOCALEDIR=\"$(localedir)\" -DLOCALE_ALIAS_PATH=\"$(aliaspath)\" \
-DLIBDIR=\"$(libdir)\" -DIN_LIBINTL \
-DENABLE_RELOCATABLE=1 -DIN_LIBRARY -DINSTALLDIR=\"$(libdir)\" -DNO_XMALLOC \
-Dset_relocation_prefix=libintl_set_relocation_prefix \
-Drelocate=libintl_relocate \
-DDEPENDS_ON_LIBICONV=1 -DHAVE_CONFIG_H -DHAVE_CONFIG_H

CPPFLAGS = 
CFLAGS = -g -O2 -Wall -Wpointer-arith -finline-functions -ffast-math -funroll-all-loops @CFLAG_VISIBILITY@ -DBUILDING_LIBINTL
LDFLAGS = 
LIBS = 

OBJECTS = dummy.o

DISTFILES.common = Makefile.in

.SUFFIXES:
.SUFFIXES: .c .y .o .lo .sin .sed

all: all-no
all-yes: libintl.a libintl.h charset.alias ref-add.sed ref-del.sed
all-no: all-no-@BUILD_INCLUDED_LIBINTL@
all-no-yes: libintl.a
all-no-no:

libintl.a:
	rm -f $@
	echo "/* Stub library */" > dummy.c
	$(CC) -c dummy.c
	$(AR) cru $@ dummy.o
	$(RANLIB) $@
	rm -f dummy.c dummy.o

.c.o:
	$(CC) $(DEFS) $(INCLUDES) $(CPPFLAGS) $(CFLAGS) -c $<

mostlyclean:
	rm -f *.a *.o core core.*

clean: mostlyclean
	rm -f libintl.h charset.alias ref-add.sed ref-del.sed

distclean: clean
	rm -f Makefile ID TAGS
	if test "xmms" = gettext; then \
	  rm -f ChangeLog.inst $(DISTFILES.normal); \
	else \
	  : ; \
	fi

maintainer-clean: distclean
	@echo "This command is intended for maintainers to use;"
	@echo "it deletes files that may require special tools to rebuild."

# GNU gettext needs not contain the file 'VERSION' but contains some
# other files which should not be distributed in other packages.
distdir = ../$(PACKAGE)-$(VERSION)/$(subdir)

Makefile: Makefile.in.in ../config.status
	cd .. \
	  && CONFIG_FILES=$(subdir)/$@ CONFIG_HEADERS= \
	       $(SHELL) ./config.status

# Tell versions [3.59,3.63) of GNU make not to export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:
